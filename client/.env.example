# Google Maps JavaScript API key (Places API enabled, restricted to
# http://localhost:5173 in dev).
VITE_GOOGLE_MAPS_KEY=

# Same OAuth Client ID as the server's GOOGLE_OAUTH_CLIENT_ID.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Where to center the map if geolocation is denied. Defaults to NYC.
VITE_DEFAULT_LAT=40.7831
VITE_DEFAULT_LNG=-73.9712
