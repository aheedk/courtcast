# --- Server config ---
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Postgres (matches docker-compose.yml) ---
DATABASE_URL=postgresql://courtcast:courtcast@localhost:5432/courtcast?schema=public

# --- Session ---
# A long random string. Cookie itself only stores a session id, but this
# guards against tampering if you switch to signed cookies later.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google ---
# Same OAuth Client ID used in the client (VITE_GOOGLE_OAUTH_CLIENT_ID).
GOOGLE_OAUTH_CLIENT_ID=
# Server-side Places API key (can be the same key as the Maps JS key,
# as long as Places API is enabled on it).
GOOGLE_PLACES_KEY=

# --- OpenWeatherMap ---
OPENWEATHER_KEY=

# --- Defaults ---
# Where to center the map if the user denies geolocation. Defaults to NYC.
DEFAULT_LAT=40.7831
DEFAULT_LNG=-73.9712
DEFAULT_RADIUS_METERS=16000
